# CPack External generator hook for the Philotechnia .AppImage artefact.
#
# Invoked by cpack when CPACK_GENERATOR includes "External" on Linux (see the
# main CMakeLists.txt). This script runs inside CPack's CMake processor.
#
# Responsibilities:
#   1. Use CPACK_TEMPORARY_INSTALL_DIRECTORY (populated by CPack because
#      CPACK_EXTERNAL_ENABLE_STAGING is ON) as the staged install tree.
#   2. Mirror that tree into an AppDir layout.
#   3. Download linuxdeploy + linuxdeploy-plugin-qt into a per-user cache
#      if they are not already present.
#   4. Invoke linuxdeploy with APPIMAGE_EXTRACT_AND_RUN=1 so FUSE is not
#      required on the build host (important for CI containers).
#   5. Produce ${PROJECT_NAME}-${PROJECT_VERSION}-x86_64.AppImage under
#      CPACK_PACKAGE_DIRECTORY, alongside the .deb.
#
# This file is the @ONLY template — the configured copy lives in the build
# tree and has PHILOTECHNIA_QMAKE_EXECUTABLE / project name / version baked
# in at main-configure time. The CPack External script runs in a fresh
# CMake context and cannot see the main project's scope directly.

set(_qmake        "@PHILOTECHNIA_QMAKE_EXECUTABLE@")
set(_project_name "@PROJECT_NAME@")
set(_project_vers "@PROJECT_VERSION@")

if(NOT CPACK_TEMPORARY_INSTALL_DIRECTORY)
    message(FATAL_ERROR
        "CPack External script invoked without CPACK_TEMPORARY_INSTALL_DIRECTORY. "
        "CPACK_EXTERNAL_ENABLE_STAGING must be ON in the main CMakeLists.txt.")
endif()
if(NOT EXISTS "${CPACK_TEMPORARY_INSTALL_DIRECTORY}")
    message(FATAL_ERROR
        "Staged install tree not found at ${CPACK_TEMPORARY_INSTALL_DIRECTORY}")
endif()

set(_output_dir "${CPACK_PACKAGE_DIRECTORY}")
set(_appdir     "${CPACK_TOPLEVEL_DIRECTORY}/philotechnia.AppDir")

message(STATUS "Philotechnia AppImage: assembling AppDir at ${_appdir}")

file(REMOVE_RECURSE "${_appdir}")
file(MAKE_DIRECTORY "${_appdir}/usr")

# Mirror the staged install tree into AppDir/usr/. The tree already has
# bin/, share/applications/, and share/icons/hicolor/256x256/apps/ shape
# because the main CMakeLists install() rules put them there.
file(GLOB _staging_children RELATIVE "${CPACK_TEMPORARY_INSTALL_DIRECTORY}"
     "${CPACK_TEMPORARY_INSTALL_DIRECTORY}/*")
foreach(_child ${_staging_children})
    file(COPY "${CPACK_TEMPORARY_INSTALL_DIRECTORY}/${_child}"
         DESTINATION "${_appdir}/usr/")
endforeach()

# linuxdeploy + linuxdeploy-plugin-qt — cached per-user so CI reruns skip
# the download on cache hits.
set(_tools_dir "$ENV{HOME}/.cache/philotechnia-build/linuxdeploy")
file(MAKE_DIRECTORY "${_tools_dir}")

set(_linuxdeploy    "${_tools_dir}/linuxdeploy-x86_64.AppImage")
set(_linuxdeploy_qt "${_tools_dir}/linuxdeploy-plugin-qt-x86_64.AppImage")

function(_philotechnia_download_if_missing path url)
    if(EXISTS "${path}")
        return()
    endif()
    message(STATUS "Downloading ${url}")
    file(DOWNLOAD "${url}" "${path}"
         SHOW_PROGRESS
         STATUS _dl_status
         TLS_VERIFY ON)
    list(GET _dl_status 0 _dl_code)
    list(GET _dl_status 1 _dl_msg)
    if(NOT _dl_code EQUAL 0)
        file(REMOVE "${path}")
        message(FATAL_ERROR "Download failed for ${url}: ${_dl_msg}")
    endif()
    execute_process(COMMAND chmod +x "${path}")
endfunction()

_philotechnia_download_if_missing("${_linuxdeploy}"
    "https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage")
_philotechnia_download_if_missing("${_linuxdeploy_qt}"
    "https://github.com/linuxdeploy/linuxdeploy-plugin-qt/releases/download/continuous/linuxdeploy-plugin-qt-x86_64.AppImage")

# Environment for linuxdeploy. APPIMAGE_EXTRACT_AND_RUN=1 makes both the
# linuxdeploy AppImage and the plugin-qt AppImage self-extract and execute
# their payload, bypassing FUSE — this is what lets the build work in a
# GitHub Actions container that has no FUSE device node.
set(_env_args
    "APPIMAGE_EXTRACT_AND_RUN=1"
    "OUTPUT=${_project_name}-${_project_vers}-x86_64.AppImage"
)
if(_qmake)
    list(APPEND _env_args "QMAKE=${_qmake}")
else()
    message(WARNING
        "No qmake was forwarded from the main configure; linuxdeploy-plugin-qt "
        "will attempt auto-discovery. If AppImage assembly fails with a Qt "
        "path error, install Qt or set QMAKE in the cpack environment.")
endif()

message(STATUS "Philotechnia AppImage: invoking linuxdeploy")
execute_process(
    COMMAND ${CMAKE_COMMAND} -E env ${_env_args}
        "${_linuxdeploy}"
            --appdir "${_appdir}"
            --desktop-file "${_appdir}/usr/share/applications/philotechnia.desktop"
            --icon-file "${_appdir}/usr/share/icons/hicolor/256x256/apps/philotechnia.png"
            --plugin qt
            --output appimage
    WORKING_DIRECTORY "${_output_dir}"
    RESULT_VARIABLE _rc
)

if(NOT _rc EQUAL 0)
    message(FATAL_ERROR "linuxdeploy failed with exit code ${_rc}")
endif()

file(GLOB _produced "${_output_dir}/*.AppImage")
if(NOT _produced)
    message(FATAL_ERROR
        "linuxdeploy returned success but no .AppImage was found in ${_output_dir}")
endif()
list(APPEND CPACK_EXTERNAL_BUILT_PACKAGES ${_produced})
message(STATUS "Philotechnia AppImage: produced ${_produced}")
