# Philotechnia formatting rules - enforced by clang-format.
# Conventions and rationale: CLAUDE.md -> Conventions -> Code style.
# Overrides LLVM defaults only; anything not listed inherits from LLVM.

Language: Cpp
BasedOnStyle: LLVM
Standard: Latest

# Layout
ColumnLimit: 100
IndentWidth: 4
TabWidth: 4
AccessModifierOffset: -4

# Pointers and references - left-attached (west-const side)
PointerAlignment: Left
ReferenceAlignment: Left
DerivePointerAlignment: false

# Wrapping - one arg per line when the call wraps; never bin-pack.
BinPackArguments: false
BinPackParameters: false
AlwaysBreakTemplateDeclarations: Yes
PackConstructorInitializers: CurrentLine

# Short-form allowances - permit `int x() const { return x_; }` inside a class
# body; never collapse free functions, `if`, or `for` to a single line.
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# Includes - see CLAUDE.md Conventions -> Code style -> Include ordering.
# The matching header for a .cpp file comes first automatically
# (MainInclude, priority 0); the categories below cover the rest.
IncludeBlocks: Regroup
SortIncludes: CaseInsensitive
IncludeCategories:
  - Regex: '^".*"$'
    Priority: 5    # project headers (quoted)
  - Regex: '^<(Qt|catch2|yyjson|git2)'
    Priority: 4    # third-party libraries
  - Regex: '^<[a-z_]+>$'
    Priority: 3    # C++ standard library
  - Regex: '^<.*\.h>$'
    Priority: 2    # C system headers
